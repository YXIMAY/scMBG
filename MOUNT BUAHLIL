-- YXI MOUNT BUAHLIL
-- Auto Teleport CP0-CP25 + Auto Drop

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")
local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")

local LocalPlayer = Players.LocalPlayer
local Checkpoints = workspace:WaitForChild("Checkpoints")
local DropEvent = ReplicatedStorage:WaitForChild("CP_DropToStart")

-- Variables
local running = false
local tweenSpeed = 0.5 -- detik per checkpoint (semakin kecil semakin cepat)
local delayPerCP = 0.3
local delayAfterDrop = 1

-- Fungsi mendapatkan karakter
local function getCharacter()
    local char = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    local hrp = char:WaitForChild("HumanoidRootPart")
    return char, hrp
end

-- Fungsi teleport tween (anti kick)
local function tweenTo(position)
    local char, hrp = getCharacter()
    local distance = (hrp.Position - position).Magnitude
    local duration = math.max(distance / 150, 0.2)
    
    local tween = TweenService:Create(hrp, TweenInfo.new(duration, Enum.EasingStyle.Linear), {CFrame = CFrame.new(position)})
    tween:Play()
    tween.Completed:Wait()
end

-- Fungsi mendapatkan posisi checkpoint
local function getCPPosition(cp)
    if cp:IsA("BasePart") then
        return cp.Position
    elseif cp:IsA("Model") then
        if cp.PrimaryPart then
            return cp.PrimaryPart.Position
        else
            for _, v in pairs(cp:GetDescendants()) do
                if v:IsA("BasePart") then
                    return v.Position
                end
            end
        end
    end
    return nil
end

-- Fungsi loop auto checkpoint
local function autoCheckpoint()
    while running do
        for i = 0, 25 do
            if not running then break end
            local cp = Checkpoints:FindFirstChild("CP" .. i)
            if cp then
                local pos = getCPPosition(cp)
                if pos then
                    tweenTo(pos + Vector3.new(0, 3, 0))
                    task.wait(delayPerCP)
                end
            end
        end
        
        if not running then break end
        
        -- Execute drop script
        pcall(function()
            DropEvent:FireServer()
        end)
        
        task.wait(delayAfterDrop)
    end
end

