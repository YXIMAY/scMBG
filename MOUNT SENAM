-- ============ Functions ============
local function getHRP()
    local char = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    return char:WaitForChild("HumanoidRootPart"), char:FindFirstChildOfClass("Humanoid")
end

local function teleportToCFrame(cframe)
    local hrp = getHRP()
    if not hrp then return end
    if useTween then
        local dist = (hrp.Position - cframe.Position).Magnitude
        local time = dist / tweenSpeed
        local tw = TweenService:Create(hrp, TweenInfo.new(time, Enum.EasingStyle.Linear), {CFrame = cframe})
        tw:Play()
        tw.Completed:Wait()
    else
        hrp.CFrame = cframe
    end
end

local function teleportToPos(x, y, z)
    teleportToCFrame(CFrame.new(x, y, z))
end

local function getCPPart(name)
    local obj = Checkpoints:FindFirstChild(name)
    if not obj then return nil end
    if obj:IsA("BasePart") then
        return obj
    else
        for _, v in ipairs(obj:GetDescendants()) do
            if v:IsA("BasePart") then
                return v
            end
        end
    end
    return nil
end

local function runLoop()
    while running do
        -- CP1 - CP36
        for i = 1, 36 do
            if not running then return end
            local cpName = "CP" .. i
            local part = getCPPart(cpName)
            if part then
                CurrentCP.Text = "Current: " .. cpName
                Status.Text = "Status: Teleporting..."
                teleportToCFrame(part.CFrame + Vector3.new(0, 3, 0))
                task.wait(delayPerCP)
            else
                CurrentCP.Text = "Current: " .. cpName .. " (NOT FOUND)"
                task.wait(0.1)
            end

            -- Cek waypoint tambahan setelah CP ini
            local wp = extraWaypoints[i]
            if wp and running then
                CurrentCP.Text = string.format("Current: Waypoint (%d,%d,%d)", wp[1], wp[2], wp[3])
                Status.Text = "Status: Teleport waypoint..."
                teleportToPos(wp[1], wp[2], wp[3])
                task.wait(delayPerCP)
            end
        end

        if not running then return end

        -- Finish
        local finish = getCPPart("Finish")
        if finish then
            CurrentCP.Text = "Current: Finish"
            Status.Text = "Status: Teleport ke Finish..."
            teleportToCFrame(finish.CFrame + Vector3.new(0, 3, 0))
            task.wait(delayPerCP)
        end

        if not running then return end

        -- Execute ReturnToBaseEvent
        Status.Text = "Status: Firing ReturnToBaseEvent..."
        local ok, err = pcall(function()
            local Event = ReplicatedStorage:WaitForChild("ReturnToBaseEvent", 5)
            Event:FireServer(0)
        end)
        if not ok then
            Status.Text = "Status: Error fire event"
        end

        task.wait(2)
    end
end

