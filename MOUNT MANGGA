-- ========== AUTO TP LOGIC ==========
local loopCount = 0

local function setStatus(txt, color)
	StatusLabel.Text = "  Status: " .. txt
	StatusLabel.TextColor3 = color or Color3.fromRGB(255, 255, 255)
end

local function setCP(txt)
	CPLabel.Text = "  CP: " .. txt
end

local function runRoute()
	while running do
		loopCount = loopCount + 1
		LoopLabel.Text = "  Loop: " .. loopCount

		-- ===== FASE 1: CP1 - CP40 =====
		setStatus("Jalur 1 (CP1-CP40)", Color3.fromRGB(0, 255, 100))
		for i = 1, 40 do
			if not running then return end
			local cp = findPart(CheckpointsFolder, "CP" .. i)
			if cp then
				teleportTo(cp)
				setCP("CP" .. i .. " / 40")
			else
				setCP("CP" .. i .. " (not found)")
			end
			task.wait(DELAY_PER_CP)
		end

		if not running then return end

		-- ===== FASE 2: Finish =====
		setStatus("Finish!", Color3.fromRGB(255, 200, 0))
		local finish = findPart(CheckpointsFolder, "Finish")
		if finish then
			teleportTo(finish)
			setCP("Finish ✅")
		end
		task.wait(DELAY_PER_CP)

		if not running then return end

		-- ===== FASE 3: CP42 - CP59 =====
		setStatus("Jalur 2 (CP42-CP59)", Color3.fromRGB(100, 200, 255))
		for i = 42, 59 do
			if not running then return end
			local cp = findPart(Jalur2Folder, "CP" .. i) or findPart(CheckpointsFolder, "CP" .. i)
			if cp then
				teleportTo(cp)
				setCP("CP" .. i .. " / 59")
			else
				setCP("CP" .. i .. " (not found)")
			end
			task.wait(DELAY_PER_CP)
		end

		if not running then return end

		-- ===== FASE 4: Finish2 =====
		setStatus("Finish2!", Color3.fromRGB(255, 200, 0))
		local finish2 = findPart(Jalur2Folder, "Finish2") or findPart(CheckpointsFolder, "Finish2")
		if finish2 then
			teleportTo(finish2)
			setCP("Finish2 ✅")
		end
		task.wait(DELAY_PER_CP)

		if not running then return end

		-- ===== FASE 5: Basecamp via Event =====
		setStatus("Return to Basecamp...", Color3.fromRGB(255, 150, 0))
		setCP("Basecamp 🏕️")
		BasecampEvent:FireServer(0)

		-- Delay 2 detik sebelum ulang
		setStatus("Waiting 2s...", Color3.fromRGB(255, 255, 100))
		task.wait(2)
	end
end

StartBtn.MouseButton1Click:Connect(function()
