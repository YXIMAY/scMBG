	setStatus("Running", Color3.fromRGB(0, 255, 100))
	StartBtn.BackgroundColor3 = Color3.fromRGB(80, 80, 80)
	StartBtn.Text = "▶  RUNNING..."
	task.spawn(runRoute)
end)

